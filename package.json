{
  "name": "requestmaker",
  "version": "0.1.0",
  "private": true,
  "author": "Lorenzo L. Concas",
  "description": "Another wrapper around curl, full open-source with teams feature powered by firebase",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "chrome:cors:win": "if exist \"%ProgramFiles%\\Google\\Chrome\\Application\\chrome.exe\" (set CHROME=%ProgramFiles%\\Google\\Chrome\\Application\\chrome.exe) else (set CHROME=%ProgramFiles(x86)%\\Google\\Chrome\\Application\\chrome.exe) && start \"\" \"%CHROME%\" --disable-web-security --user-data-dir=\"%TEMP%\\requestmaker-chrome\" \"http://localhost:5173\"",
    "chrome:cors:linux": "google-chrome --disable-web-security --user-data-dir=/tmp/requestmaker-chrome \"http://localhost:5173\"",
    "chrome:cors:mac": "open -na \"Google Chrome\" --args --disable-web-security --user-data-dir=\"/tmp/requestmaker-chrome\" \"http://localhost:5173\"",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:all": "npm run build && electron-builder --mac --linux --win"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^11.2.0",
    "lucide-vue-next": "^0.542.0",
    "pinia": "^3.0.1",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.41",
    "shadcn-vue": "^2.3.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.7.3",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.requestmaker.app",
    "productName": "RequestMaker",
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
